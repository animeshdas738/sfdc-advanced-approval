<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Configurable criteria rows for an Approval Process. Criteria in the same Logic Group are AND-ed; different groups are OR-ed: (G1C1 AND G1C2) OR (G2C1 AND G2C2).</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>false</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <fields>
        <fullName>Process__c</fullName>
        <externalId>false</externalId>
        <label>Approval Process</label>
        <referenceTo>Approval_Process__c</referenceTo>
        <relationshipLabel>Approval Criteria</relationshipLabel>
        <relationshipName>Approval_Criteria</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>false</reparentableMasterDetail>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>Field_API_Name__c</fullName>
        <description>API name of the field to evaluate. Use dot notation for parent fields (e.g. Account.Industry).</description>
        <externalId>false</externalId>
        <label>Field API Name</label>
        <length>255</length>
        <required>true</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Operator__c</fullName>
        <description>Comparison operator to apply against Value__c</description>
        <externalId>false</externalId>
        <label>Operator</label>
        <required>true</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Equals</fullName><default>true</default><label>Equals</label></value>
                <value><fullName>Not Equals</fullName><default>false</default><label>Not Equals</label></value>
                <value><fullName>Greater Than</fullName><default>false</default><label>Greater Than</label></value>
                <value><fullName>Less Than</fullName><default>false</default><label>Less Than</label></value>
                <value><fullName>Greater or Equal</fullName><default>false</default><label>Greater or Equal</label></value>
                <value><fullName>Less or Equal</fullName><default>false</default><label>Less or Equal</label></value>
                <value><fullName>Contains</fullName><default>false</default><label>Contains</label></value>
                <value><fullName>Starts With</fullName><default>false</default><label>Starts With</label></value>
                <value><fullName>In</fullName><default>false</default><label>In (comma-separated)</label></value>
                <value><fullName>Not In</fullName><default>false</default><label>Not In (comma-separated)</label></value>
                <value><fullName>Is Null</fullName><default>false</default><label>Is Null</label></value>
                <value><fullName>Is Not Null</fullName><default>false</default><label>Is Not Null</label></value>
                <value><fullName>Changed</fullName><default>false</default><label>Changed (any value)</label></value>
                <value><fullName>Changed To</fullName><default>false</default><label>Changed To</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Value__c</fullName>
        <description>Comparison value. For In/Not In use comma-separated list. For Date use YYYY-MM-DD. Not required for Is Null, Is Not Null, Changed.</description>
        <externalId>false</externalId>
        <label>Value</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Field_Type__c</fullName>
        <description>Data type of the field — used for accurate comparison (numeric vs text vs date)</description>
        <externalId>false</externalId>
        <label>Field Type</label>
        <required>true</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Text</fullName><default>true</default><label>Text / Picklist</label></value>
                <value><fullName>Number</fullName><default>false</default><label>Number / Currency / Percent</label></value>
                <value><fullName>Boolean</fullName><default>false</default><label>Boolean (Checkbox)</label></value>
                <value><fullName>Date</fullName><default>false</default><label>Date</label></value>
                <value><fullName>DateTime</fullName><default>false</default><label>DateTime</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>Logic_Group__c</fullName>
        <description>Criteria in the same group are AND-ed together; groups are OR-ed. Default 1.</description>
        <defaultValue>1</defaultValue>
        <externalId>false</externalId>
        <label>Logic Group</label>
        <precision>3</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Sort_Order__c</fullName>
        <description>Evaluation order within the logic group</description>
        <defaultValue>1</defaultValue>
        <externalId>false</externalId>
        <label>Sort Order</label>
        <precision>3</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <label>Approval Criteria</label>
    <listViews>
        <fullName>All</fullName>
        <columns>NAME</columns>
        <columns>Field_API_Name__c</columns>
        <columns>Operator__c</columns>
        <columns>Value__c</columns>
        <columns>Logic_Group__c</columns>
        <columns>Sort_Order__c</columns>
        <filterScope>Everything</filterScope>
        <label>All</label>
    </listViews>
    <nameField>
        <displayFormat>AC-{00000}</displayFormat>
        <label>Criteria Number</label>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Approval Criteria</pluralLabel>
    <sharingModel>ControlledByParent</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
